{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext", // implies moduleResolution: "nodenext"
    "outDir": "./dist",
    "rootDir": "./",

    // migration ergonomics
    "allowJs": true, // lets .ts and .js coexist while you migrate
    "checkJs": false, //! TODO: flip to true later if you want errors in remaining .js files

    // correctness
    "strict": true, // start strict; new .ts files get full checking
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true, // don't type-check node_modules .d.ts files
    "sourceMap": true
  },
  "include": ["**/*"],
  "exclude": ["dist", "node_modules"]
}
